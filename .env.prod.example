# ───────────────────────────────────────────────
# 生产环境变量模板
# 用法：cp .env.prod.example .env.prod 然后填入真实值
# 启动：docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ⚠ .env.prod 含密钥，切勿提交到 git
# ───────────────────────────────────────────────

# MySQL root 密码（mysql 容器初始化 + 后端连接共用）
# 生成强密码：openssl rand -base64 24
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_db_password

# 数据库名（一般无需改）
MYSQL_DB=chatgpt2api_pro

# Redis 密码（留空=不启用密码；公网务必设置）
# 生成：openssl rand -base64 24
REDIS_PASS=

# JWT 签名密钥（务必随机，泄露 = 任何人可伪造登录态）
# 生成：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_64_hex_chars

# 超级管理员邮箱：该邮箱的用户登录后强制获得最高权限（可授予/撤销其他用户的管理员）。
# 需先用此邮箱注册一个普通账号，登录后即自动成为超级管理员。改人只需改此值。
SUPERADMIN_EMAIL=you@example.com

# CORS 允许来源（同源 Nginx 反代部署可留空；跨域直连时填前端域名，逗号分隔）
# 例：ALLOWED_ORIGINS=https://your-domain.com
ALLOWED_ORIGINS=

# 对外映射端口（绑定 127.0.0.1，给宝塔 Nginx 反代用）
# 若宿主机 3000/8080 已被占用，改成空闲端口，并同步修改宝塔反代目标端口
FRONTEND_PORT=3000
BACKEND_PORT=8080

# HTTP server 超时（秒）。防慢连接堆积吃内存；改后需重启容器生效。
# ⚠ 不要给后端设 WriteTimeout——会掐断 SSE 长连接（账号监控/注册机实时日志）。
# 读请求头超时（防 slowloris 慢速攻击），0=不限
HTTP_READ_HEADER_TIMEOUT_SEC=15
# 空闲连接回收超时（keep-alive），0=不限
HTTP_IDLE_TIMEOUT_SEC=120
