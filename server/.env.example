# 本地开发环境变量模板
# 用法：cp .env.example .env 然后按需修改
# 生产部署请用根目录 .env.prod.example + docker-compose.prod.yml

# 服务端口
PORT=8080

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=chatgpt2api_pro

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# JWT 签名密钥（生产务必改为随机值：openssl rand -hex 32）
JWT_SECRET=dev-secret-change-me

# 额外允许的 CORS 来源，逗号分隔（同源部署可留空）
ALLOWED_ORIGINS=
